# AWS environment for the remote CloudLab `lc-bench node` daemon.
#
# Copy this file to:
#
#   cloudlab/.config/aws.env
#
# Then fill it locally. Do not commit the copied file.
#
# Static credentials:
# AWS_ACCESS_KEY_ID=<access-key-id>
# AWS_SECRET_ACCESS_KEY=<secret-access-key>
#
# Temporary STS credentials also need:
# AWS_SESSION_TOKEN=<session-token>
#
# Region defaults for AWS managed S3/DynamoDB experiments:
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2
